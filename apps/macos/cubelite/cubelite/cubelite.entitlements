<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <!--
        App Sandbox is intentionally disabled: CubeLite is distributed
        directly (GitHub Releases / Developer ID, #121), not via the Mac App
        Store, and kubeconfig exec credential plugins (kubelogin, aws,
        gke-gcloud-auth-plugin) require spawning external binaries, which the
        sandbox forbids (#108). Re-introduce a sandboxed configuration only
        if an App Store target ever materialises.
    -->
        <key>com.apple.security.app-sandbox</key>
        <false/>
    </dict>
</plist>
